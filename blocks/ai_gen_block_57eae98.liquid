{% doc %}
  @prompt
    Create a scrolling marquee announcement bar section that continuously scrolls text from right to left. It should display two messages: "Kostenloser Versand in Europe" and "Erhalte 15% Rabatt auf deine Bestellung". The messages should repeat seamlessly as they scroll. The bar should use a dark background (matching color scheme 3: #142621) with light text (#F5F0EB), be compact in height, and have smooth continuous animation. Each message should be separated by a decorative divider (e.g. a dot or dash). The scroll speed should be customizable.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-marquee-announcement-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    overflow: hidden;
    position: relative;
    padding: {{ block.settings.bar_height }}px 0;
  }

  .ai-marquee-track-{{ ai_gen_id }} {
    display: flex;
    width: max-content;
    animation: ai-marquee-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  .ai-marquee-content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    white-space: nowrap;
    padding-right: 40px;
  }

  .ai-marquee-message-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    margin: 0;
  }

  .ai-marquee-divider-{{ ai_gen_id }} {
    margin: 0 {{ block.settings.divider_spacing }}px;
    opacity: 0.6;
  }

  @keyframes ai-marquee-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-marquee-track-{{ ai_gen_id }} {
      animation: none;
    }
  }
{% endstyle %}

<marquee-announcement-{{ ai_gen_id }}
  class="ai-marquee-announcement-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-marquee-track-{{ ai_gen_id }}">
    {% for i in (1..2) %}
      <div class="ai-marquee-content-{{ ai_gen_id }}">
        {% if block.settings.message_1 != blank %}
          <span class="ai-marquee-message-{{ ai_gen_id }}">{{ block.settings.message_1 }}</span>
          <span class="ai-marquee-divider-{{ ai_gen_id }}">{{ block.settings.divider }}</span>
        {% endif %}

        {% if block.settings.message_2 != blank %}
          <span class="ai-marquee-message-{{ ai_gen_id }}">{{ block.settings.message_2 }}</span>
          <span class="ai-marquee-divider-{{ ai_gen_id }}">{{ block.settings.divider }}</span>
        {% endif %}

        {% if block.settings.message_1 != blank %}
          <span class="ai-marquee-message-{{ ai_gen_id }}">{{ block.settings.message_1 }}</span>
          <span class="ai-marquee-divider-{{ ai_gen_id }}">{{ block.settings.divider }}</span>
        {% endif %}

        {% if block.settings.message_2 != blank %}
          <span class="ai-marquee-message-{{ ai_gen_id }}">{{ block.settings.message_2 }}</span>
          <span class="ai-marquee-divider-{{ ai_gen_id }}">{{ block.settings.divider }}</span>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</marquee-announcement-{{ ai_gen_id }}>

<script>
  (function() {
    class MarqueeAnnouncement{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustSpeed();
      }

      adjustSpeed() {
        const track = this.querySelector('.ai-marquee-track-{{ ai_gen_id }}');
        if (!track) return;

        const content = this.querySelector('.ai-marquee-content-{{ ai_gen_id }}');
        if (!content) return;

        const contentWidth = content.offsetWidth;
        const speed = {{ block.settings.scroll_speed }};
        const duration = (contentWidth / 100) * speed;

        track.style.animationDuration = duration + 's';
      }
    }

    customElements.define('marquee-announcement-{{ ai_gen_id }}', MarqueeAnnouncement{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Scrolling marquee bar",
  "settings": [
    {
      "type": "header",
      "content": "Messages"
    },
    {
      "type": "text",
      "id": "message_1",
      "label": "Message 1",
      "default": "Kostenloser Versand in Europe"
    },
    {
      "type": "text",
      "id": "message_2",
      "label": "Message 2",
      "default": "Erhalte 15% Rabatt auf deine Bestellung"
    },
    {
      "type": "text",
      "id": "divider",
      "label": "Divider",
      "default": "•"
    },
    {
      "type": "range",
      "id": "divider_spacing",
      "label": "Divider spacing",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#142621"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#F5F0EB"
    },
    {
      "type": "range",
      "id": "bar_height",
      "label": "Bar height",
      "min": 8,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "400"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scroll speed",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "s",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Scrolling marquee bar"
    }
  ]
}
{% endschema %}
