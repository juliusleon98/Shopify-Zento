{% doc %}
  @prompt
    Update the existing scrolling marquee announcement bar block to support three messages instead of two. The three messages are: "Kostenloser Versand in Europe", "Erhalte 15% Rabatt auf deine Bestellung", and "30 Tage Geld-Zurück-Garantie". The bar should continuously scroll all three messages from right to left, seamlessly repeating. Keep the same dark background (#142621) with light text (#F5F0EB), compact height, smooth animation, and decorative separators between messages. Each message should be a customizable setting in the theme editor., can we please remove the divider bullet point?
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-marquee-bar-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    overflow: hidden;
    position: relative;
    padding: {{ block.settings.bar_height }}px 0;
  }

  .ai-marquee-track-{{ ai_gen_id }} {
    display: flex;
    width: max-content;
    animation: ai-marquee-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  .ai-marquee-content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .ai-marquee-message-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    padding: 0 {{ block.settings.message_spacing }}px;
    display: inline-flex;
    align-items: center;
  }

  @keyframes ai-marquee-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-marquee-message-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<marquee-bar-{{ ai_gen_id }} class="ai-marquee-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-marquee-track-{{ ai_gen_id }}">
    <div class="ai-marquee-content-{{ ai_gen_id }}">
      {% if block.settings.message_1 != blank %}
        <span class="ai-marquee-message-{{ ai_gen_id }}">{{ block.settings.message_1 }}</span>
      {% endif %}
      {% if block.settings.message_2 != blank %}
        <span class="ai-marquee-message-{{ ai_gen_id }}">{{ block.settings.message_2 }}</span>
      {% endif %}
      {% if block.settings.message_3 != blank %}
        <span class="ai-marquee-message-{{ ai_gen_id }}">{{ block.settings.message_3 }}</span>
      {% endif %}
    </div>
    <div class="ai-marquee-content-{{ ai_gen_id }}" aria-hidden="true">
      {% if block.settings.message_1 != blank %}
        <span class="ai-marquee-message-{{ ai_gen_id }}">{{ block.settings.message_1 }}</span>
      {% endif %}
      {% if block.settings.message_2 != blank %}
        <span class="ai-marquee-message-{{ ai_gen_id }}">{{ block.settings.message_2 }}</span>
      {% endif %}
      {% if block.settings.message_3 != blank %}
        <span class="ai-marquee-message-{{ ai_gen_id }}">{{ block.settings.message_3 }}</span>
      {% endif %}
    </div>
  </div>
</marquee-bar-{{ ai_gen_id }}>

<script>
  (function() {
    class MarqueeBar{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        this.setAttribute('role', 'region');
        this.setAttribute('aria-label', 'Announcement bar');
      }
    }

    customElements.define('marquee-bar-{{ ai_gen_id }}', MarqueeBar{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Scrolling marquee bar",
  "settings": [
    {
      "type": "header",
      "content": "Messages"
    },
    {
      "type": "text",
      "id": "message_1",
      "label": "Message 1",
      "default": "Kostenloser Versand in Europe"
    },
    {
      "type": "text",
      "id": "message_2",
      "label": "Message 2",
      "default": "Erhalte 15% Rabatt auf deine Bestellung"
    },
    {
      "type": "text",
      "id": "message_3",
      "label": "Message 3",
      "default": "30 Tage Geld-Zurück-Garantie"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#142621"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#F5F0EB"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "bar_height",
      "label": "Bar height",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "message_spacing",
      "label": "Message spacing",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scroll speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Scrolling marquee bar"
    }
  ]
}
{% endschema %}
