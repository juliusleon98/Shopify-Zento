        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Zento trust strip",
      "blocks": [
        { "type": "item", "settings": { "icon": "return", "heading": "30 Tage testen", "text": "Risikofrei zuhause ausprobieren" } },
        { "type": "item", "settings": { "icon": "truck", "heading": "Kostenloser Versand", "text": "Schnell & sicher geliefert" } },
